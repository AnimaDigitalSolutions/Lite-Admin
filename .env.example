# Server Configuration
NODE_ENV=development
PORT=3001

# Admin Authentication
ADMIN_USERNAME=admin@email.com
ADMIN_PASSWORD=changeme
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database Configuration (choose one)
DB_TYPE=sqlite                 # sqlite|postgres|mysql
DB_PATH=./database/lite.db     # For SQLite
DB_URL=                        # For PostgreSQL/MySQL

# Email Provider Configuration (choose one)
EMAIL_PROVIDER=ahasend         # ahasend|resend
AHASEND_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@animadigitalsolutions.com

# Storage Provider Configuration (choose one)
STORAGE_PROVIDER=local         # local|s3
AWS_ACCESS_KEY_ID=             # For S3
AWS_SECRET_ACCESS_KEY=         # For S3
AWS_REGION=                    # For S3
AWS_S3_BUCKET=                 # For S3

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://animadigitalsolutions.com

# Rate Limiting
RATE_LIMIT_WINDOW=30           # seconds
RATE_LIMIT_MAX=10              # requests per window

# Logging
LOG_LEVEL=info                 # error|warn|info|debug

# File Upload Limits
MAX_FILE_SIZE=10485760         # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Image Optimization
IMAGE_QUALITY=85               # 1-100
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300